# ---- 系统/临时 ----
.DS_Store
__pycache__/
*.pyc
*.env
.env
.idea/

# ---- Python 构建产物 ----
*.egg-info/
build/
dist/
.ipynb_checkpoints/

# ---- 生成产物 ----
# outputs/ 目录结构入库，但重量级二进制（模型 pickle）不入库；
# 图表(figures)、表格(tables)、审计报告作为交付物保留。
outputs/models/*.pkl
outputs/models/*.pt
outputs/models/*.joblib

# ---- 数据 ----
# raw_data 全部不入库（约 5-6 GB，仅保留本地），只收录说明文档
# 数据来源与目录说明见 raw_data/README.md
raw_data/*
!raw_data/README.md

# 兜底：任何 gz 归档
*.csv.gz
